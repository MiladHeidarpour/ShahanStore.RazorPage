@page "{id}"
@using ShahanStore.RazorPage.Infrastructure
@using ShahanStore.RazorPage.Infrastructure.ViewModels
@using ShahanStore.RazorPage.Infrastructure.ViewModels.Categories
@using ShahanStore.RazorPage.Models.Queries.Categories
@model ShahanStore.RazorPage.Areas.Admin.Pages.Categories.DetailModel
@{
    var siteSeo = new PageHeaderModel()
    {
        Title = "جزئیات دسته‌بندی",
        Breadcrumbs = new List<BreadcrumbItem>
        {
        new BreadcrumbItem { Text = "دشبرد", Url = "/Admin" },
        new BreadcrumbItem { Text = "دسته‌بندی ها",Url = "/Admin/Categories"},
        new BreadcrumbItem { Text = $"جزئیات دسته‌بندی {Model.Category.Title}", IsActive = true }
        }
    };

    ViewData["Title"] = siteSeo.Title;
}



@await Html.PartialAsync("_PageTitleHead", siteSeo)
<div class="row">

    <partial name="_CategoryDetail" model="@Model.Category" />


    @if (Model.Category.Children.Count > 0)
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header border-bottom border-light">
                    <form asp-page="Index" method="get">
                        <div class="row justify-content-between g-3">
                            <div class="col-lg-6">
                                <div class="row g-3">
                                    <div class="col-lg-6">
                                        <div class="position-relative">
                                            <input asp-for="Search" type="text" class="form-control ps-4" placeholder="جستجو دسته‌بندی">
                                            <i class="ti ti-search position-absolute top-50 translate-middle-y ms-2"></i>
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="flex-grow-1 d-flex align-items-center">
                                            <label for="status-select" class="me-2">وضعیت</label>
                                            <div class="flex-grow-1">
                                                <select asp-for="Status" class="form-select my-1 my-md-0 " data-toggle="select2" id="status-select" data-select2-id="status-select" tabindex="-1" aria-hidden="true">
                                                    <option value="null">همه</option>
                                                    <option value="@Status.Active">فعال</option>
                                                    <option value="@Status.NotActive">غیرفعال</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="text-md-end mt-3 mt-md-0">

                                    <open-modal asp-page="Index"
                                                asp-page-handler="AddChildPartial"
                                                asp-route-id="@Model.Category.Id"
                                                modal-title="افزودن زیردسته‌بندی"
                                                class="btn btn-dark waves-effect waves-light me-1">
                                        <i class="ti ti-plus me-1"></i>افزودن زیردسته‌بندی
                                    </open-modal>

                                    <button type="submit" class="btn btn-success  waves-effect waves-light"><i class="ti ti-filter me-1"></i> فیلترها</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover text-nowrap mb-0">
                        <thead class="bg-light-subtle">
                            <tr>
                                <th></th>
                                <th>دسته‌بندی</th>
                                <th>رتبه مشتری (1-5)</th>
                                <th>وضعیت</th>
                                <th class="text-center" style="width: 120px;">فعالیت</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Category.Children)
                            {
                                var tableRowModel = CategoryTableRowVM.FromChildCategoryDto(item);
                                <tr>
                                    <td></td>
                                    <td>
                                        <div class="d-flex justify-content-start align-items-center gap-3">
                                            <div class="avatar-xl rounded-circle">
                                                @if (item.Icon is null)
                                                {
                                                    <img api-src="@($"{AppDirectories.CategoryIcon}/Nabi_icon.jpg")"
                                                         alt="@Model.Category.Title"
                                                         class="img-fluid rounded-start"
                                                         modal-page="Index"
                                                         modal-page-handler="ChangeIconPartial"
                                                         modal-route-id="@item.Id" />
                                                }
                                                else
                                                {
                                                    <img api-src="@($"{AppDirectories.CategoryIcon}/{item.Icon}")"
                                                         alt="@Model.Category.Title"
                                                         class="img-fluid rounded-2"
                                                         modal-page="Index"
                                                         modal-page-handler="ChangeIconPartial"
                                                         modal-route-id="@item.Id" />
                                                }
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-medium text-nowrap">@tableRowModel.Title</span>
                                                <span class="text-dark fw-semibold">اسلاگ: <span class="fw-normal">@tableRowModel.Slug</span></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td> <span class="badge p-1 bg-light text-dark fs-12 me-1"><i class="ti ti-star-filled align-text-top fs-14 text-warning me-1"></i> 4.5</span></td>
                                    <td>
                                        @if (tableRowModel.IsDeleted)
                                        {
                                            <span class="badge bg-danger-subtle text-danger fs-12 p-1">غیرفعال</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success fs-12 p-1">فعال</span>
                                        }
                                    </td>
                                    <td class="pe-3">
                                        <div class="hstack gap-1 justify-content-end">
                                            <a asp-page="Detail" asp-route-id="@tableRowModel.Id" class="btn btn-soft-primary btn-icon btn-sm rounded-circle"><i class="ti ti-eye"></i> </a>
                                            <open-modal asp-page="Index"
                                                        asp-page-handler="EditPartial"
                                                        asp-route-id="@tableRowModel.Id"
                                                        modal-title="ویرایش دسته‌بندی"
                                                        class="btn btn-soft-warning btn-icon btn-sm rounded-circle">
                                                <i class="ti ti-pencil-cog"></i>
                                            </open-modal>
                                            <delete_Item asp-page="Index"
                                                         asp-page-handler="DeletePartial"
                                                         asp-route-id="@tableRowModel.Id"
                                                         class="btn btn-soft-danger btn-icon btn-sm rounded-circle">
                                                <i class="ti ti-trash"></i>
                                            </delete_Item>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
<partial name="_Modal" />
