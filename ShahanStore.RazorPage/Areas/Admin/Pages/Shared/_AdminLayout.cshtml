@using Microsoft.AspNetCore.Mvc.TagHelpers
@using ShahanStore.RazorPage.Infrastructure.RazorUtils
@using ShahanStore.RazorPage.Infrastructure.ViewModels
<!DOCTYPE html>
<html lang="en" dir="rtl">

<head>
    <meta charset="utf-8" />
    <title>شاهان استور | @ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="A fully featured admin theme which can be used to build CRM, CMS, etc." name="description" />
    <meta content="Coderthemes" name="author" />

    <!-- App favicon -->
    <link rel="shortcut icon" href="~/Admin/assets/images/favicon.ico">
    <!-- سوییت الرت css-->
    <link href="~/Admin/assets/vendor/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
    <!-- CustomCss -->
    <link rel="shortcut icon" href="~/Admin/assets/css/Custom.css">
    <!-- Vendor css -->
    <link href="~/Admin/assets/css/vendor.min.css" rel="stylesheet" type="text/css" />
    <!-- App css -->
    <link href="~/Admin/assets/css/app.min.css" rel="stylesheet" type="text/css" id="app-style" />
    <!-- Icons css -->
    <link href="~/Admin/assets/css/icons.min.css" rel="stylesheet" type="text/css" />

</head>
    
<body>
    <!-- Begin page -->
    <div class="wrapper">

        <partial name="_SideBar" />
        <partial name="_Header" />

        <!-- Search Modal -->
        <div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="searchModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content bg-transparent">
                    <div class="card mb-0 shadow-none">
                        <div class="px-3 py-2 d-flex flex-row align-items-center" id="top-search">
                            <i class="ti ti-search fs-22"></i>
                            <input type="search" class="form-control border-0" id="search-modal-input"
                                   placeholder="جستجو برای موارد مختلف....">
                            <button type="button" class="btn p-0" data-bs-dismiss="modal"
                                    aria-label="Close">
                                [esc]
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="page-content">
            <div class="page-container">
                @RenderBody()
            </div>
            <partial name="_Footer" />
        </div>

    </div>


    <!-- END wrapper -->
    <!-- Vendor js -->
    <script src="~/Admin/assets/js/vendor.min.js"></script>
    <script src="~/Admin/assets/vendor/flatpickr/jdate.min.js"></script>
    <script>window.Date = window.JDate;</script>
    <script src="~/Admin/assets/vendor/flatpickr/fa.js"></script>
    <!-- Theme Config Js -->
    <script src="~/Admin/assets/js/config.js"></script>
    <!-- App js -->
    <script src="~/Admin/assets/js/app.js"></script>
    <!-- Projects Analytics دشبرد App js -->
    <script src="~/Admin/assets/js/pages/dashboard-sales.js"></script>
    <!-- Sweet Alerts js -->
    <script src="~/Admin/assets/vendor/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/Admin/assets/js/Global.js"></script>


    <div id="ajax-token">
        @Html.AntiForgeryToken()
    </div>
    @await RenderSectionAsync("Scripts", required: false)

    <partial name="_ValidationScriptsPartial" />
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    @if (TempData[BasePageModel.AlertKey] is not null)
    {
        <script>
            var alertData = JSON.parse('@Html.Raw(TempData[BasePageModel.AlertKey])');
            console.log(alertData);
            if(alertData.Type === 'Success')
            {
                Success(null, alertData.Message);
            }
            else if (alertData.Type === 'Error')
            {
                ErrorAlert(null, alertData.Message);
            }
            else if (alertData.Type === 'Warning')
            {
                Warning(null, alertData.Message);
            }
        </script>
    }
</body>

</html>